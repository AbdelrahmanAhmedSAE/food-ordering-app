else
  export NODE_PATH="/home/abdelrahmen/food-ordering-app/node_modules/.pnpm/tsup@8.5.1_@swc+core@1.15.33_jiti@2.6.1_postcss@8.5.15_typescript@5.9.3/node_modules/tsup/node_modules:/home/abdelrahmen/food-ordering-app/node_modules/.pnpm/tsup@8.5.1_@swc+core@1.15.33_jiti@2.6.1_postcss@8.5.15_typescript@5.9.3/node_modules:/home/abdelrahmen/food-ordering-app/node_modules/.pnpm/node_modules:$NODE_PATH"
fi
if [ -n "$exe" ] && [ -x "$basedir/node.exe" ]; then
  exec "$basedir/node.exe"  "$basedir_win/../tsup/dist/cli-node.js" "$@"
elif [ -x "$basedir/node" ]; then
  exec "$basedir/node"  "$basedir/../tsup/dist/cli-node.js" "$@"
elif command -v node >/dev/null 2>&1; then
  exec node  "$basedir/../tsup/dist/cli-node.js" "$@"
elif [ -n "$exe" ] && command -v node.exe >/dev/null 2>&1; then
  exec node.exe  "$basedir_win/../tsup/dist/cli-node.js" "$@"
